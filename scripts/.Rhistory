check_pd_all <- function(vcv_list) {
lapply(names(vcv_list), function(sp) {
results <- sapply(vcv_list[[sp]], is_pd_chol)
data.frame(
species     = sp,
n_total     = length(results),
n_pd        = sum(results),
n_not_pd    = sum(!results),
pct_pd      = mean(results) * 100
)
}) |> bind_rows()
}
check_pd_all(vcv_list)
is_pd_chol <- function(m) {
tryCatch({
chol(m)
TRUE
}, error = function(e) FALSE)
}
check_pd_all <- function(vcv_list) {
lapply(names(vcv_list), function(sp) {
results <- sapply(vcv_list[[sp]], is_pd_chol)
data.frame(
species     = sp,
n_total     = length(results),
n_pd        = sum(results),
n_not_pd    = sum(!results),
pct_pd      = mean(results) * 100
)
}) |> bind_rows()
}
check_pd_all(vcv_list)
