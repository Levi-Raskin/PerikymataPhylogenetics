geom_text(data = tile_data,
aes(x = x, y = y, label = round(value, 1)),
inherit.aes = FALSE,
size   = 3.5,
color  = "black",
family = "Georgia")
combinedPlot <- evoVCV + treeAndHeatmap +
plot_layout(widths = c(1, 2))
combinedPlot
ggsave(paste0(output, "fig1.svg"), width = 14, height = 8)
